candidate_scores = []

print("Scoring candidates...")

for features in candidate_features:

    tech = technical_score(features)

    behavior = behavioral_score(features)

    logistics = logistics_score(features)

    penalty = penalty_score(features)

    final_score = (
        tech
        + behavior
        + logistics
        - penalty
    )

    candidate_scores.append({
      "candidate_id": features["candidate_id"],
        "technical_score": tech,
        "behavioral_score": behavior,
        "logistics_score": logistics,
        "penalty_score": penalty,
        "final_score": final_score
    })
    

print("Scoring completed.")
