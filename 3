import json

def technical_score(features):
    score = 0

    # Experience
    years = features.get("years_experience", 0)

    if 4 <= years < 5:
        score += 10
    elif 5 <= years <= 9:
        score += 15 + (years - 5)
    elif 9 < years <= 12:
        score += 20

    # Machine Learning Experience
    if features.get("has_ml", False):
        score += 10

    # Retrieval / Recommendation / Search Experience
    if features.get("has_retrieval_experience", False):
        score += 20

    # Leadership Experience
    if features.get("has_leadership", False):
        score += 5

    return score

def behavioral_score(features):
    score = 0

    # Open to Work
    if features.get("open_to_work", False):
        score += 5

    # Recruiter Response Rate
    response_rate = features.get("response_rate", 0)
    score += response_rate * 10

    # Interview Completion Rate
    interview_completion = features.get("interview_completion", 0)

    if interview_completion >= 0.8:
        score += 5

    # Recruiter Interest
    saved_by_recruiters = features.get("saved_by_recruiters", 0)

    if saved_by_recruiters >= 10:
        score += 5
    elif saved_by_recruiters >= 5:
        score += 3

    return score

def logistics_score(features):
    score = 0

    # Notice Period
    notice_period = features.get("notice_period", 180)

    if notice_period <= 30:
        score += 5
    elif notice_period <= 60:
        score += 3

    return score

def penalty_score(features):
    penalty = 0

    # Consulting-only candidates
    if features.get("consulting_only", False):
        penalty += 20

    return penalty
